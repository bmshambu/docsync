# ── LLM provider ───────────────────────────────────────────────
# Set to "google" (default) or "azure_openai"
LLM_PROVIDER=google

# ── Google AI ──────────────────────────────────────────────────
# Get a free key from https://aistudio.google.com/app/apikey

GOOGLE_API_KEY=""


# ── Models (Gemini) ────────────────────────────────────────────
# Gemini 2.5 Flash is the default for all three steps.
MODEL_EXTRACT="gemini-2.5-flash"
MODEL_SUMMARY="gemini-2.5-flash"
MODEL_QUERY="gemini-2.5-flash"

# ── Pipeline tuning ────────────────────────────────────────────
# How many documents to send to the LLM in parallel during entity extraction.
MAX_LLM_CONCURRENCY=5
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# ── Azure OpenAI (set LLM_PROVIDER=azure_openai to use these) ──
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ── Storage ────────────────────────────────────────────────────
# Where the app writes extracted_text/, chunks/, graph/ etc.
DATA_DIR=data
